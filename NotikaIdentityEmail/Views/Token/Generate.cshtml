@model SimpleUserViewModel
@{
    ViewData["Title"] = "Generate";
    Layout = "~/Views/UserLayout/Index.cshtml";
}


<style>

    .alert-danger {
        background: #85C79A;
        border: 1px solid #519A66;
        border-radius: 10px;
        padding: 12px 16px;
        margin-bottom: 18px;
        display: none;
    }

        .alert-danger:has(.text-white:not(:empty)) {
            display: block;
        }

    .text-white {
        padding-inline-start: 5px;
        color: #48A111;
        font-size: 13px;
        line-height: 1.5;
    }

    .validation-msg {
        font-size: 12px;
        color: #C00707;
        margin-top: 6px;
        padding: 6px 10px;
        background: rgba(239, 68, 68, 0.08);
        border: 1px solid rgba(239, 68, 68, 0.2);
        border-radius: 8px;
        display: none;
    }

        .validation-msg:not(:empty) {
            display: block;
        }
</style>

<div class="inbox-area">
    <div class="container">
        <div class="row">
            <div class="row">
                <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                    <div class="form-example-wrap mg-t-30">
                        <div class="cmp-tb-hd cmp-int-hd">
                            <h2>Bilgilere Göre Token Oluştur</h2>
                            <p>Lütfen bilgilerinizi eksiksiz bir şekilde doldurunuz. Doldurma işlemini tamamladıktan sonra bilgilerinizi kontrol ederek token oluşturma işlemini gerçekleştirebilirsiniz.</p>
                        </div>
                        <form method="post">

                            <div class="form-example-int form-horizental">
                                <div class="form-group">
                                    <div class="row">
                                        <div class="col-lg-2 col-md-3 col-sm-3 col-xs-12">
                                            <label class="hrzn-fm">Ad: </label>
                                        </div>
                                        <div class="col-lg-8 col-md-7 col-sm-7 col-xs-12">
                                            <div class="nk-int-st">
                                                <input type="text" asp-for="Name" class="form-control input-sm" placeholder="Adınızı Giriniz">
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="form-example-int form-horizental">
                                <div class="form-group">
                                    <div class="row">
                                        <div class="col-lg-2 col-md-3 col-sm-3 col-xs-12">
                                            <label class="hrzn-fm">Soyad: </label>
                                        </div>
                                        <div class="col-lg-8 col-md-7 col-sm-7 col-xs-12">
                                            <div class="nk-int-st">
                                                <input type="text" asp-for="Surname" class="form-control input-sm" placeholder="Soyadınızı Giriniz">
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="form-example-int form-horizental">
                                <div class="form-group">
                                    <div class="row">
                                        <div class="col-lg-2 col-md-3 col-sm-3 col-xs-12">
                                            <label class="hrzn-fm">Şehir: </label>
                                        </div>
                                        <div class="col-lg-8 col-md-7 col-sm-7 col-xs-12">
                                            <div class="nk-int-st">
                                                <input type="text" asp-for="City" class="form-control input-sm" placeholder="Şehrinizi Giriniz">
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="form-example-int form-horizental">
                                <div class="form-group">
                                    <div class="row">
                                        <div class="col-lg-2 col-md-3 col-sm-3 col-xs-12">
                                            <label class="hrzn-fm">Username: </label>
                                        </div>
                                        <div class="col-lg-8 col-md-7 col-sm-7 col-xs-12">
                                            <div class="nk-int-st">
                                                <input type="text" asp-for="Username" class="form-control input-sm" placeholder="Kullanıcı Adı Giriniz">
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="form-example-int mg-t-15">
                                <div class="row">
                                    <div class="col-lg-2 col-md-3 col-sm-3 col-xs-12">
                                    </div>
                                    <div class="col-lg-8 col-md-7 col-sm-7 col-xs-12">
                                        <button class="btn btn-success notika-btn-success">Token Oluştur</button>
                                    </div>
                                </div>
                            </div>
                            @if (Model != null && Model.Token != null)
                            {
                                <div class="alert alert-success">
                                    <span>Token Başarıyla Oluşturuldu</span>
                                </div>
                                <textarea asp-for="Token" class="form form-control" rows="6"></textarea>
                            }

                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>



