@model List<Notification>
@{
    int count = 0;
}

<style>
    /* Her satırı hizala */
    .hd-message-sn {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 10px;
        transition: 0.3s;
    }

    /* Hover efekti */
    .notification-item:hover {
        background-color: #f5f5f5;
        text-decoration: none;
    }

    /* Resim alanını SABİTLE */
    .hd-message-img {
        width: 50px;
        height: 50px;
        flex-shrink: 0;
    }

        .hd-message-img img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            border-radius: 50%;
        }

    /* Metin alanı */
    .hd-mg-ctn {
        flex: 1;
    }

        /* Başlık */
        .hd-mg-ctn h3 {
            margin: 0;
            font-size: 14px;
            font-weight: 600;
        }

        /* Açıklama */
        .hd-mg-ctn p {
            margin: 2px 0 0;
            font-size: 13px;
            color: #666;
        }
</style>


<li class="nav-item">
    <a href="#" data-toggle="dropdown" role="button" class="nav-link dropdown-toggle">
        <span><i class="notika-icon notika-menus"></i></span>
        <div class="ntd-ctn"><span>@Model.Count</span></div>
    </a>

    <div class="dropdown-menu message-dd task-dd animated zoomIn">

        <div class="hd-mg-tt">
            <h2>Bildirimler (@Model.Count)</h2>
        </div>

        <div class="hd-message-info">
            @foreach (var item in Model)
            {
                count++;
                <a href="#" class="notification-item">
                    <div class="hd-message-sn">

                        <div class="hd-message-img">
                            <img src="@item.ImageUrl" alt="notification">
                        </div>

                        <div class="hd-mg-ctn">
                            <h3>Bildirim @count</h3>
                            <p>@item.Detail</p>
                        </div>

                    </div>
                </a>
            }
        </div>

        <div class="hd-mg-va">
            <a href="/Notification/NotificationList">Tümünü Gör</a>
        </div>

    </div>
</li>