@model List<MessageWithImagesViewModel>


<li class="nav-item dropdown">
    <a href="#" data-toggle="dropdown" role="button" aria-expanded="false" class="nav-link dropdown-toggle"><span><i class="notika-icon notika-mail"></i></span></a>
    <div role="menu" class="dropdown-menu message-dd animated zoomIn">
        <div class="hd-mg-tt">
            <h2>Okunmamış Gelen Mesajlar (@Model.Count)</h2>
        </div>
        <div class="hd-message-info">
            @foreach (var item in Model)
            {
                <a href="#">
                <div class="hd-message-sn">
                    <div class="hd-message-img">
                            <img src="@item.UserImage" alt="" />
                    </div>
                    <div class="hd-mg-ctn">
                        <h3>@item.SenderEmail</h3>
                            <p>@item.MessageDetail</p>
                    </div>
                </div>
            </a>
            }
        </div>
        <div class="hd-mg-va">
            <a href="/Message/Inbox">Tümünü Gör</a>
        </div>
    </div>
</li>
<li class="nav-item nc-al">
    <a href="#" data-toggle="dropdown" role="button" aria-expanded="false" class="nav-link dropdown-toggle"><span><i class="notika-icon notika-alarm"></i></span><div class="spinner4 spinner-4"></div><div class="ntd-ctn"><span>@Model.Count</span></div></a>
    <div role="menu" class="dropdown-menu message-dd animated zoomIn">
        <div class="hd-mg-tt">
            <h2>Okunmamış Gelen Mesajlar (@Model.Count)</h2>
        </div>
        <div class="hd-message-info">
            @foreach (var item in Model)
            {
                <a href="/Message/MessageDetail?messageId=@item.MessageId">
                    <div class="hd-message-sn">
                        <div class="hd-message-img">
                            <img src="@item.UserImage" alt="" />
                        </div>
                        <div class="hd-mg-ctn">
                            <h3>@item.SenderEmail</h3>
                            <p>@item.MessageDetail</p>
                        </div>
                    </div>
                </a>
            }
        </div>
        <div class="hd-mg-va">
            <a href="/Message/Inbox">Tümünü Gör</a>
        </div>
    </div>
</li>
