@model ForgetPasswordViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8">
    <title>Notika – Şifremi Unuttum</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
    <style>
        /* Login sayfasındaki CSS kök değerleri ve resetler */
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        :root {
            --sky-50: #f0f9ff;
            --sky-400: #38bdf8;
            --sky-500: #0ea5e9;
            --sky-600: #0284c7;
            --white: #ffffff;
            --text-dark: #0c2340;
            --text-mid: #3b6ca8;
            --text-soft: #7aadcf;
            --card-bg: rgba(255,255,255,0.72);
            --radius: 20px;
        }

        body {
            font-family: 'DM Sans', sans-serif;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: radial-gradient(ellipse 80% 60% at 10% 20%, #c7e9fb 0%, transparent 60%), linear-gradient(160deg, #dbeffe 0%, #eff8ff 50%, #ddf4ff 100%);
            padding: 24px;
            overflow: hidden;
        }

        /* Arka plan dekoratif elementler */
        .dots {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 0;
            background-image: radial-gradient(circle, rgba(14,165,233,0.12) 1px, transparent 1px);
            background-size: 36px 36px;
        }

        .card {
            position: relative;
            z-index: 1;
            background: var(--card-bg);
            backdrop-filter: blur(28px);
            -webkit-backdrop-filter: blur(28px);
            border: 1px solid rgba(255,255,255,0.85);
            border-radius: var(--radius);
            padding: 48px 44px;
            width: 100%;
            max-width: 440px;
            box-shadow: 0 24px 60px rgba(2,132,199,0.12);
        }

        .header {
            text-align: center;
            margin-bottom: 32px;
        }

        .brand-icon {
            width: 44px;
            height: 44px;
            background: linear-gradient(135deg, var(--sky-400), var(--sky-600));
            border-radius: 12px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 18px;
            box-shadow: 0 6px 20px rgba(14,165,233,0.4);
        }

            .brand-icon svg {
                width: 22px;
                height: 22px;
                fill: white;
            }

        .brand-name {
            font-family: 'Sora', sans-serif;
            font-size: 26px;
            font-weight: 700;
            color: var(--text-dark);
            display: block;
            margin-bottom: 8px;
        }

        .header p {
            font-size: 14px;
            color: var(--text-soft);
            line-height: 1.5;
        }

        .form-group {
            margin-bottom: 24px;
        }

            .form-group label {
                display: block;
                font-size: 11.5px;
                font-weight: 600;
                color: var(--text-mid);
                text-transform: uppercase;
                letter-spacing: 0.9px;
                margin-bottom: 7px;
            }

        .input-wrap {
            position: relative;
        }

        .input-icon {
            position: absolute;
            left: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--sky-400);
        }

            .input-icon svg {
                width: 18px;
                height: 18px;
            }

        .input-text {
            width: 100%;
            padding: 14px 14px 14px 44px;
            background: rgba(240,249,255,0.7);
            border: 1.5px solid rgba(14,165,233,0.18);
            border-radius: 12px;
            font-size: 14px;
            outline: none;
            transition: all 0.22s;
        }

            .input-text:focus {
                border-color: var(--sky-400);
                background: white;
                box-shadow: 0 0 0 3px rgba(56,189,248,0.15);
            }

        .btn-send {
            width: 100%;
            padding: 14px;
            background: linear-gradient(135deg, var(--sky-400) 0%, var(--sky-600) 100%);
            border: none;
            border-radius: 13px;
            color: white;
            font-size: 15px;
            font-weight: 600;
            font-family: 'Sora', sans-serif;
            cursor: pointer;
            box-shadow: 0 8px 24px rgba(14,165,233,0.38);
            transition: all 0.25s ease;
        }

            .btn-send:hover {
                transform: translateY(-2px);
                box-shadow: 0 14px 36px rgba(14,165,233,0.48);
            }

        .back-to-login {
            text-align: center;
            margin-top: 24px;
            font-size: 13.5px;
        }

            .back-to-login a {
                color: var(--sky-600);
                text-decoration: none;
                font-weight: 600;
                transition: color 0.2s;
            }

                .back-to-login a:hover {
                    color: var(--sky-700);
                }

        .alert-success {
            background-color: #ecfdf5; /* Çok açık yeşil */
            border-left: 5px solid #10b981; /* Sol tarafta kalın yeşil çizgi */
            color: #065f46; /* Koyu yeşil yazı */
            padding: 15px;
            border-radius: 8px;
            margin-bottom: 20px;
            font-size: 14px;
            font-weight: 500;
            display: flex;
            align-items: center;
        }

            /* İsteğe bağlı: Küçük bir check işareti */
            .alert-success::before {
                content: '✓';
                margin-right: 10px;
                font-weight: bold;
                font-size: 18px;
            }
    </style>
</head>
<body>
    <div class="dots"></div>

    <div class="card">
        <div class="header">
            <div class="brand-icon">
                <svg viewBox="0 0 24 24"><path d="M12.65 10C11.83 7.67 9.61 6 7 6c-3.31 0-6 2.69-6 6s2.69 6 6 6c2.61 0 4.83-1.67 5.65-4H17v4h4v-4h2v-4H12.65zM7 14c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2z" /></svg>
            </div>
            <span class="brand-name">Şifremi Unuttum</span>
            <p>E-posta adresinizi girin, size şifre sıfırlama bağlantısı gönderelim.</p>
        </div>

        @if (TempData["SendMailProcess"] != null)
        {
            <div class="alert alert-success">
                @TempData["SendMailProcess"]
            </div>
        }

        <form  method="post">
            <div class="form-group">
                <label>E-Posta Adresi</label>
                <div class="input-wrap">
                    <span class="input-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                            <polyline points="22,6 12,13 2,6"></polyline>
                        </svg>
                    </span>
                    <input type="email" class="input-text" asp-for="Email" placeholder="ornek@mail.com" required>
                </div>
            </div>

            <button type="submit" class="btn-send">Sıfırlama Bağlantısı Gönder</button>
        </form>

        <div class="back-to-login">
            <a href="/Login/Userlogin">← Giriş sayfasına dön</a>
        </div>
    </div>

    <script>
        // Sayfa öğelerinin sırayla gelmesi için basit animasyon tetikleyici
        document.querySelectorAll('.header, .form-group, .btn-send, .back-to-login').forEach((el, i) => {
            el.style.opacity = '0';
            el.style.transform = 'translateY(10px)';
            el.style.transition = `all 0.4s ease ${0.1 + i * 0.1}s`;
            setTimeout(() => {
                el.style.opacity = '1';
                el.style.transform = 'translateY(0)';
            }, 50);
        });
    </script>
</body>
</html>