@model CreateRoleViewModel
@{
    ViewData["Title"] = "Yeni Rol Oluştur";
    Layout = "~/Views/UserLayout/Index.cshtml";
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');

    :root {
        --primary-gradient: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);
        --bg: #f1f5f9;
        --surface: #ffffff;
        --border: #e2e8f0;
        --text-main: #1e293b;
        --text-muted: #64748b;
        --radius-lg: 16px;
        --radius-md: 10px;
        --success: #10b981;
        --warning: #f59e0b;
    }

    .page-wrapper {
        font-family: 'Inter', sans-serif;
        background: var(--bg);
        padding: 60px 0;
        min-height: 100vh;
    }

    /* ── Form Card ── */
    .form-card {
        background: var(--surface);
        border-radius: var(--radius-lg);
        border: 1px solid var(--border);
        box-shadow: 0 10px 15px -3px rgba(0,0,0,0.04);
        padding: 40px;
        max-width: 800px;
        margin: 0 auto;
    }

    .header-section {
        text-align: center;
        margin-bottom: 35px;
        padding-bottom: 20px;
        border-bottom: 1px solid var(--border);
    }

        .header-section h2 {
            font-size: 24px;
            font-weight: 700;
            color: var(--text-main);
            margin: 0;
        }

        .header-section p {
            color: var(--text-muted);
            margin-top: 10px;
            font-size: 14px;
            line-height: 1.6;
        }

    /* ── Inputs ── */
    .form-group-custom {
        margin-bottom: 25px;
    }

    .label-custom {
        display: block;
        font-weight: 600;
        color: var(--text-main);
        margin-bottom: 8px;
        font-size: 14px;
    }

    .input-custom {
        width: 100%;
        padding: 12px 16px;
        border: 1px solid var(--border);
        border-radius: var(--radius-md);
        font-size: 14px;
        background: #f8fafc;
        transition: all 0.3s;
    }

        .input-custom:focus {
            outline: none;
            border-color: #4f46e5;
            background: #fff;
            box-shadow: 0 0 0 4px rgba(79, 70, 229, 0.1);
        }

    /* ── Buttons ── */
    .action-area {
        display: flex;
        gap: 12px;
        margin-top: 30px;
    }

    .btn-custom {
        padding: 12px 24px;
        border-radius: var(--radius-md);
        font-weight: 600;
        font-size: 14px;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        transition: all 0.2s;
        border: none;
        cursor: pointer;
    }

    .btn-save {
        background: var(--primary-gradient);
        color: white;
        flex: 2;
    }

        .btn-save:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(79, 70, 229, 0.3);
        }

    .btn-back {
        background: #f1f5f9;
        color: var(--text-main);
        flex: 1;
        border: 1px solid var(--border);
    }

        .btn-back:hover {
            background: #e2e8f0;
        }

    /* ── Alerts ── */
    .alert-custom {
        padding: 14px;
        border-radius: var(--radius-md);
        margin-bottom: 20px;
        font-size: 14px;
        font-weight: 500;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .alert-success-custom {
        background: #ecfdf5;
        color: #065f46;
        border: 1px solid #a7f3d0;
    }

</style>

<div class="page-wrapper">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <div class="form-card">

                    <div class="header-section">
                        <h2>Yeni Rol Ataması Yap</h2>
                        <p>
                            Lütfen yeni rol adını eksiksiz giriniz.
                            Bu işlem yalnızca sistem yöneticileri tarafından gerçekleştirilebilir.
                        </p>
                    </div>

                    @if (TempData["success"] != null)
                    {
                        <div class="alert-custom alert-success-custom">
                            <i class="notika-icon notika-checked"></i>
                            @TempData["success"]
                        </div>
                    }

                    <form method="post">
                        <div class="form-group-custom">
                            <label class="label-custom" asp-for="RoleName">Rol Adı</label>
                            <input type="text" asp-for="RoleName" class="input-custom" placeholder="Örn: Editör, Moderatör..." required>
                        </div>

                        <div class="action-area">
                            <button type="submit" class="btn-custom btn-save">
                                <i class="notika-icon notika-checked"></i> Bilgileri Kaydet
                            </button>
                            <a href="/Role/RoleList" class="btn-custom btn-back">
                                <i class="notika-icon notika-back"></i> Listeye Dön
                            </a>
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>