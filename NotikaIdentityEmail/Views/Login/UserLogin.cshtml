@model UserLoginViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8">
    <title>Notika – Giriş</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        :root {
            --sky-50: #f0f9ff;
            --sky-100: #e0f2fe;
            --sky-200: #bae6fd;
            --sky-300: #7dd3fc;
            --sky-400: #38bdf8;
            --sky-500: #0ea5e9;
            --sky-600: #0284c7;
            --sky-700: #0369a1;
            --indigo-400: #818cf8;
            --white: #ffffff;
            --text-dark: #0c2340;
            --text-mid: #3b6ca8;
            --text-soft: #7aadcf;
            --card-bg: rgba(255,255,255,0.72);
            --radius: 20px;
        }

        body {
            font-family: 'DM Sans', sans-serif;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: radial-gradient(ellipse 80% 60% at 10% 20%, #c7e9fb 0%, transparent 60%), radial-gradient(ellipse 70% 50% at 90% 80%, #bfdbfe 0%, transparent 55%), radial-gradient(ellipse 60% 70% at 55% 10%, #e0f2fe 0%, transparent 50%), linear-gradient(160deg, #dbeffe 0%, #eff8ff 50%, #ddf4ff 100%);
            padding: 24px;
            overflow: hidden;
        }

            body::before, body::after {
                content: '';
                position: fixed;
                border-radius: 50%;
                filter: blur(60px);
                pointer-events: none;
                z-index: 0;
                animation: float 8s ease-in-out infinite alternate;
            }

            body::before {
                width: 400px;
                height: 400px;
                background: rgba(56,189,248,0.22);
                top: -100px;
                left: -100px;
            }

            body::after {
                width: 350px;
                height: 350px;
                background: rgba(129,140,248,0.15);
                bottom: -80px;
                right: -80px;
                animation-delay: -4s;
            }

        .dots {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 0;
            background-image: radial-gradient(circle, rgba(14,165,233,0.12) 1px, transparent 1px);
            background-size: 36px 36px;
        }

        .card {
            position: relative;
            z-index: 1;
            background: var(--card-bg);
            backdrop-filter: blur(28px);
            -webkit-backdrop-filter: blur(28px);
            border: 1px solid rgba(255,255,255,0.85);
            border-radius: var(--radius);
            padding: 48px 44px 40px;
            width: 100%;
            max-width: 440px;
            box-shadow: 0 4px 6px rgba(14,165,233,0.06), 0 24px 60px rgba(2,132,199,0.12), inset 0 1px 0 rgba(255,255,255,0.9);
            animation: slideUp 0.6s cubic-bezier(0.22,1,0.36,1) both;
        }

        /* Header */
        .header {
            text-align: center;
            margin-bottom: 32px;
        }

        .brand-mark {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 18px;
        }

        .brand-icon {
            width: 44px;
            height: 44px;
            background: linear-gradient(135deg, var(--sky-400), var(--sky-600));
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 6px 20px rgba(14,165,233,0.4);
        }

            .brand-icon svg {
                width: 22px;
                height: 22px;
                fill: white;
            }

        .brand-name {
            font-family: 'Sora', sans-serif;
            font-size: 26px;
            font-weight: 700;
            color: var(--text-dark);
            letter-spacing: -0.5px;
        }

            .brand-name span {
                color: var(--sky-500);
            }

        .header p {
            font-size: 14px;
            color: var(--text-soft);
            font-weight: 400;
        }

        /* Social login */
        .social-row {
            display: flex;
            gap: 10px;
            margin-bottom: 24px;
        }

            .social-row form {
                flex: 1;
                min-width: 0;
            }

        .social-btn {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 7px;
            padding: 11px 8px;
            width: 100%;
            background: white;
            border: 1.5px solid rgba(14,165,233,0.18);
            border-radius: 12px;
            cursor: pointer;
            font-size: 12.5px;
            font-family: 'DM Sans', sans-serif;
            font-weight: 500;
            color: var(--text-dark);
            text-decoration: none;
            transition: all 0.2s ease;
            box-shadow: 0 2px 8px rgba(14,165,233,0.06);
            white-space: nowrap;
            overflow: hidden;
        }

            .social-btn:hover {
                border-color: var(--sky-400);
                box-shadow: 0 4px 16px rgba(14,165,233,0.18);
                transform: translateY(-1px);
            }

            .social-btn svg {
                width: 18px;
                height: 18px;
                flex-shrink: 0;
            }

            .social-btn span {
                overflow: hidden;
                text-overflow: ellipsis;
            }

        /* Divider */
        .divider {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 22px;
            color: var(--text-soft);
            font-size: 12px;
        }

            .divider::before, .divider::after {
                content: '';
                flex: 1;
                height: 1px;
                background: rgba(14,165,233,0.15);
            }

        /* Form */
        .form-group {
            margin-bottom: 16px;
        }

            .form-group label {
                display: block;
                font-size: 11.5px;
                font-weight: 600;
                color: var(--text-mid);
                text-transform: uppercase;
                letter-spacing: 0.9px;
                margin-bottom: 7px;
            }

        .input-wrap {
            position: relative;
        }

        .alert-danger {
            background: rgba(239, 68, 68, 0.1);
            border: 1px solid rgba(239, 68, 68, 0.25);
            border-radius: 10px;
            padding: 12px 16px;
            margin-bottom: 18px;
            display: none;
        }

            .alert-danger:has(.text-white:not(:empty)) {
                display: block;
            }

        .text-white {
            padding-inline-start: 7px;
            color: #C00707;
            font-size: 13px;
            line-height: 1.5;
        }

        .input-icon {
            position: absolute;
            left: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--sky-400);
            pointer-events: none;
        }

            .input-icon svg {
                width: 17px;
                height: 17px;
            }

        .input-text {
            width: 100%;
            padding: 12px 14px 12px 42px;
            background: rgba(240,249,255,0.7);
            border: 1.5px solid rgba(14,165,233,0.18);
            border-radius: 12px;
            font-size: 14px;
            font-family: 'DM Sans', sans-serif;
            color: var(--text-dark);
            outline: none;
            transition: all 0.22s ease;
        }

            .input-text::placeholder {
                color: rgba(123,173,207,0.7);
            }

            .input-text:focus {
                border-color: var(--sky-400);
                background: white;
                box-shadow: 0 0 0 3px rgba(56,189,248,0.15);
            }

        /* Password toggle */
        .toggle-pw {
            position: absolute;
            right: 14px;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            cursor: pointer;
            color: var(--text-soft);
            padding: 2px;
            display: flex;
            transition: color 0.2s;
        }

            .toggle-pw:hover {
                color: var(--sky-500);
            }

            .toggle-pw svg {
                width: 17px;
                height: 17px;
            }

        /* Remember + forgot */
        .extras {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 22px;
        }

        .remember {
            display: flex;
            align-items: center;
            gap: 8px;
            cursor: pointer;
            font-size: 13px;
            color: var(--text-mid);
            user-select: none;
        }

            .remember input[type="checkbox"] {
                display: none;
            }

        .check-box {
            width: 18px;
            height: 18px;
            border: 1.5px solid rgba(14,165,233,0.35);
            border-radius: 6px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: white;
            transition: all 0.2s ease;
            flex-shrink: 0;
        }

        .remember input:checked ~ .check-box {
            background: var(--sky-500);
            border-color: var(--sky-500);
        }

        .check-box svg {
            width: 11px;
            height: 11px;
            fill: white;
            opacity: 0;
            transition: opacity 0.15s;
        }

        .remember input:checked ~ .check-box svg {
            opacity: 1;
        }

        .forgot {
            font-size: 13px;
            color: var(--sky-500);
            text-decoration: none;
            font-weight: 500;
            transition: color 0.2s;
        }

            .forgot:hover {
                color: var(--sky-700);
            }

        /* Submit */
        .btn-login {
            width: 100%;
            padding: 14px;
            background: linear-gradient(135deg, var(--sky-400) 0%, var(--sky-600) 100%);
            border: none;
            border-radius: 13px;
            color: white;
            font-size: 15px;
            font-weight: 600;
            font-family: 'Sora', sans-serif;
            cursor: pointer;
            letter-spacing: 0.2px;
            box-shadow: 0 8px 24px rgba(14,165,233,0.38);
            transition: all 0.25s ease;
            position: relative;
            overflow: hidden;
        }

            .btn-login::after {
                content: '';
                position: absolute;
                inset: 0;
                background: linear-gradient(135deg, rgba(255,255,255,0.15), transparent);
                border-radius: inherit;
            }

            .btn-login:hover {
                transform: translateY(-2px);
                box-shadow: 0 14px 36px rgba(14,165,233,0.48);
            }

            .btn-login:active {
                transform: translateY(0);
                box-shadow: 0 4px 12px rgba(14,165,233,0.28);
            }

        /* Register link */
        .register-link {
            text-align: center;
            margin-top: 22px;
            font-size: 13.5px;
            color: var(--text-soft);
        }

            .register-link a {
                color: var(--sky-600);
                text-decoration: none;
                font-weight: 600;
                margin-left: 4px;
                transition: color 0.2s;
            }

                .register-link a:hover {
                    color: var(--sky-700);
                }
    </style>
</head>
<body>
    <div class="dots"></div>

    <div class="card">
        <div class="header">
            <div class="brand-mark">
                <div class="brand-icon">
                    <svg viewBox="0 0 24 24"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 3c1.93 0 3.5 1.57 3.5 3.5S13.93 13 12 13s-3.5-1.57-3.5-3.5S10.07 6 12 6zm7 13H5v-.23c0-.62.28-1.2.76-1.58C7.47 15.82 9.64 15 12 15s4.53.82 6.24 2.19c.48.38.76.97.76 1.58V19z" /></svg>
                </div>
                <span class="brand-name">Notika</span>
            </div>
            <p>Hesabınıza giriş yapın</p>
        </div>

        <form method="post">
            <div class="form-group">
                <label>Kullanıcı Adı</label>
                <div class="input-wrap">
                    <span class="input-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                            <circle cx="12" cy="7" r="4" />
                        </svg>
                    </span>
                    <input type="text" class="input-text" asp-for="Username" placeholder="Kullanıcı Adınızı Giriniz" autocomplete="username">
                </div>
            </div>

            <div class="form-group">
                <label>Şifre</label>
                <div class="input-wrap">
                    <span class="input-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                            <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                        </svg>
                    </span>
                    <input type="password" class="input-text" asp-for="Password" id="pwField" placeholder="••••••••" autocomplete="current-password">
                    <button type="button" class="toggle-pw" onclick="togglePw()" id="toggleBtn">
                        <svg id="eyeShow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                            <circle cx="12" cy="12" r="3" />
                        </svg>
                        <svg id="eyeHide" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:none">
                            <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24" />
                            <line x1="1" y1="1" x2="23" y2="23" />
                        </svg>
                    </button>
                </div>
            </div>

            <div class="extras">
                <label class="remember">
                    <input type="checkbox" asp-for="RememberMe" id="rememberMe">
                    <span class="check-box">
                        <svg viewBox="0 0 12 12"><polyline points="2,6 5,9 10,3" stroke="white" stroke-width="1.8" fill="none" stroke-linecap="round" stroke-linejoin="round" /></svg>
                    </span>
                    Beni hatırla
                </label>
                <a href="/PasswordChange/ForgetPassword" class="forgot">Şifremi unuttum</a>
            </div>

            <div class="alert alert-danger">
                <div asp-validation-summary="ModelOnly" class="text-white"></div>
            </div>
            <button type="submit" class="btn-login">Giriş Yap</button>
        </form>

        <div class="divider" style="margin-top:22px;">veya şununla giriş yap</div>

        <!-- Social Login -->
        <div class="social-row">
            <!-- Google -->
            <form asp-controller="Login" asp-action="ExternalLogin" method="post">
                <input type="hidden" name="provider" value="Google" />
                <button type="submit" class="social-btn">
                    <svg viewBox="0 0 24 24">
                        <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4" />
                        <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853" />
                        <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05" />
                        <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335" />
                    </svg>
                    <span>Google</span>
                </button>
            </form>

            <!-- Facebook -->
            <form asp-controller="Login" asp-action="ExternalLogin" method="post">
                <input type="hidden" name="provider" value="Facebook" />
                <button type="submit" class="social-btn">
                    <svg viewBox="0 0 24 24">
                        <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" fill="#1877F2" />
                    </svg>
                    <span>Facebook</span>
                </button>
            </form>

            <!-- X (Twitter) -->
            <form asp-controller="Login" asp-action="ExternalLogin" method="post">
                <input type="hidden" name="provider" value="Twitter" />
                <button type="submit" class="social-btn">
                    <svg viewBox="0 0 24 24">
                        <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" fill="#000000" />
                    </svg>
                    <span>X</span>
                </button>
            </form>
        </div>

        <div class="register-link">
            Hesabın yok mu?
            <a href="/Register/CreateUser">Kayıt ol</a>
        </div>
    </div>

    <script>
        function togglePw() {
            const field = document.getElementById('pwField');
            const show  = document.getElementById('eyeShow');
            const hide  = document.getElementById('eyeHide');
            if (field.type === 'password') {
                field.type = 'text';
                show.style.display = 'none';
                hide.style.display = 'block';
            } else {
                field.type = 'password';
                show.style.display = 'block';
                hide.style.display = 'none';
            }
        }

        document.querySelectorAll('.social-btn, .form-group, .extras, .btn-login, .register-link').forEach((el, i) => {
            el.style.opacity = '0';
            el.style.transform = 'translateY(14px)';
            el.style.transition = `opacity 0.45s ease ${0.15 + i * 0.07}s, transform 0.45s ease ${0.15 + i * 0.07}s`;
            setTimeout(() => { el.style.opacity = '1'; el.style.transform = 'translateY(0)'; }, 50);
        });
    </script>
</body>
</html>
