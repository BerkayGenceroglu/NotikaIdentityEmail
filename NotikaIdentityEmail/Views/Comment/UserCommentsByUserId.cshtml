@model List<Comment>
@{
    ViewData["Title"] = "UserCommentsByUserId";
    Layout = "~/Views/UserLayout/Index.cshtml";
}

<style>
    .forum-wrapper {
        max-width: 860px;
        margin: 0 auto;
        padding: 1.5rem 1rem;
        font-family: 'Segoe UI', sans-serif;
    }

    .forum-header {
        border-left: 4px solid #00c292;
        padding-left: 1rem;
    }

        .forum-header h2 {
            font-size: 1.75rem;
            font-weight: 700;
            color: #1a1a2e;
            margin: 0 0 0.25rem;
        }

        .forum-header p {
            font-size: 0.9rem;
            color: #888;
            margin: 0;
        }

    .forum-header-row {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 1rem;
        margin-bottom: 2rem;
    }

    .btn-back {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        background: #00c292;
        color: #ffffff;
        font-size: 0.85rem;
        font-weight: 600;
        padding: 0.5rem 1.1rem;
        border-radius: 8px;
        text-decoration: none;
        border: none;
        cursor: pointer;
        transition: background 0.2s ease, transform 0.15s ease;
        white-space: nowrap;
    }

        .btn-back:hover {
            background: #00a67d;
            transform: translateY(-1px);
            color: #ffffff;
            text-decoration: none;
        }

        .btn-back svg {
            width: 15px;
            height: 15px;
            stroke: #ffffff;
            fill: none;
            stroke-width: 2;
            stroke-linecap: round;
            stroke-linejoin: round;
        }

    .comment-list {
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
    }

    .comment-card {
        background: #ffffff;
        border: 1px solid #ebebf5;
        border-radius: 14px;
        padding: 1.25rem 1.5rem;
        display: flex;
        gap: 1rem;
        transition: box-shadow 0.2s ease, transform 0.2s ease;
    }

        .comment-card:hover {
            box-shadow: 0 6px 24px rgba(0, 194, 146, 0.08);
            transform: translateY(-2px);
        }

    .avatar-wrap {
        flex-shrink: 0;
    }

        .avatar-wrap img {
            width: 48px;
            height-48px;
            height: 48px;
            border-radius: 50%;
            object-fit: cover;
            border: 2px solid #ebebf5;
        }

    .comment-body {
        flex: 1;
        min-width: 0;
    }

    .comment-meta {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin-bottom: 0.5rem;
    }

    .comment-author {
        font-size: 0.925rem;
        font-weight: 600;
        color: #1a1a2e;
    }

    .comment-date {
        font-size: 0.78rem;
        color: #aaa;
    }

    .comment-text {
        font-size: 0.9rem;
        color: #444;
        line-height: 1.65;
        margin: 0 0 0.6rem;
    }

    .comment-status {
        display: inline-block;
        font-size: 0.72rem;
        font-weight: 600;
        padding: 3px 10px;
        border-radius: 20px;
        background: #eef0ff;
        color: #6c63ff;
        letter-spacing: 0.02em;
    }

    .empty-state {
        text-align: center;
        padding: 4rem 2rem;
        color: #aaa;
        font-size: 0.9rem;
    }

    @@media (max-width: 576px) {
        .comment-card {
            flex-direction: column;
            align-items: flex-start;
        }
    }
</style>

<div class="forum-wrapper">
    <div class="forum-header-row">
        <div class="forum-header">
            <h2>Yorumlarım</h2>
            <p>Aşağıda yapmış olduğunuz yorumları görmektesiniz</p>
        </div>
        <a asp-controller="Comment" asp-action="UserComments" class="btn-back">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <polyline points="15 18 9 12 15 6" />
            </svg>
            Tüm Yorumlara Dön
        </a>
    </div>

    <div class="comment-list">
        @if (Model != null && Model.Any())
        {
            @foreach (var item in Model)
            {
                <div class="comment-card">
                    <div class="avatar-wrap">
                        <img src="@item.AppUser.ImageUrl" alt="@item.AppUser.Name @item.AppUser.Surname" />
                    </div>
                    <div class="comment-body">
                        <div class="comment-meta">
                            <span class="comment-author">@item.AppUser.Name @item.AppUser.Surname</span>
                            <span class="comment-date">@item.CommentDate.ToString("dd/MM/yyyy")</span>
                        </div>
                        <p class="comment-text">@item.CommentDetail</p>
                        <span class="comment-status">@item.CommentStatus</span>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="empty-state">Henüz yorum yapılmamış.</div>
        }
    </div>
</div>
