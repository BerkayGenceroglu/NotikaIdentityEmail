@model List<Message>

@{
    ViewData["Title"] = "Taslaklar";
    Layout = "~/Views/UserLayout/Index.cshtml";
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap');

    :root {
        --primary-gradient: linear-gradient(135deg, #f59e0b 0%, #d97706 100%); /* Taslaklar için Turuncu Tonu */
        --primary-soft: #fffbeb;
        --primary-dark: #b45309;
        --bg: #f1f5f9;
        --surface: #ffffff;
        --border: #e2e8f0;
        --text-main: #1e293b;
        --text-muted: #64748b;
        --danger: #ef4444;
        --radius-lg: 16px;
        --radius-md: 10px;
    }

    .inbox-wrapper {
        font-family: 'Inter', sans-serif;
        background: var(--bg);
        padding: 40px 0;
        min-height: 100vh;
    }

    /* ── Toolbar ── */
    .inbox-toolbar {
        display: flex;
        align-items: center;
        gap: 15px;
        margin-bottom: 25px;
    }

    .search-box {
        position: relative;
        flex: 1;
    }

        .search-box input {
            width: 100%;
            padding: 12px 15px 12px 45px;
            border: 1px solid var(--border);
            border-radius: var(--radius-md);
            font-size: 14px;
            background: var(--surface);
            transition: all 0.3s;
        }

            .search-box input:focus {
                outline: none;
                border-color: #f59e0b;
                box-shadow: 0 0 0 4px rgba(245, 158, 11, 0.1);
            }

    .search-icon-fixed {
        position: absolute;
        left: 15px;
        top: 50%;
        transform: translateY(-50%);
        color: var(--text-muted);
        font-size: 18px;
    }

    /* ── Info Banner ── */
    .info-banner {
        background: var(--primary-soft);
        border: 1px solid #fde68a;
        padding: 12px 20px;
        border-radius: var(--radius-md);
        margin-bottom: 20px;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        color: var(--primary-dark);
        font-weight: 600;
    }

    /* ── Table & Card ── */
    .inbox-card {
        background: var(--surface);
        border-radius: var(--radius-lg);
        border: 1px solid var(--border);
        box-shadow: 0 10px 15px -3px rgba(0,0,0,0.04);
        overflow: hidden;
    }

    .table-responsive-custom {
        width: 100%;
        overflow-x: auto;
    }

    .inbox-table {
        width: 100%;
        border-collapse: collapse;
        table-layout: fixed; /* Taşmayı önleyen kritik ayar */
    }

        .inbox-table thead {
            background: #f8fafc;
            border-bottom: 1px solid var(--border);
        }

        .inbox-table th {
            padding: 18px 20px;
            text-align: left;
            font-size: 11px;
            text-transform: uppercase;
            color: var(--text-muted);
            letter-spacing: 0.05em;
            font-weight: 700;
        }

    .message-row {
        border-bottom: 1px solid var(--border);
        transition: all 0.2s;
    }

        .message-row:hover {
            background: #fffdfa; /* Taslaklara özel hafif sarımtırak hover */
        }

        .message-row td {
            padding: 16px 20px;
            vertical-align: middle;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

    /* Sütun Genişlikleri */
    .col-receiver {
        width: 30%;
    }

    .col-category {
        width: 150px;
    }

    .col-subject {
        width: auto;
    }

    .col-date {
        width: 120px;
        text-align: right;
    }

    .col-actions {
        width: 120px;
        text-align: center;
    }

    /* ── Badges ── */
    .cat-badge {
        padding: 4px 10px;
        border-radius: 6px;
        font-size: 11px;
        font-weight: 600;
        display: inline-block;
    }

    .bg-edu {
        background: #ffedd5;
        color: #9a3412;
    }

    .bg-soc {
        background: #dcfce7;
        color: #166534;
    }

    .bg-fin {
        background: #dbeafe;
        color: #1e40af;
    }

    .bg-def {
        background: #f1f5f9;
        color: #475569;
    }

    /* ── Buttons ── */
    .btn-go {
        background: #f59e0b;
        color: white;
        padding: 6px 12px;
        border-radius: 6px;
        font-size: 12px;
        font-weight: 600;
        text-decoration: none;
        transition: background 0.2s;
    }

        .btn-go:hover {
            background: #d97706;
            color: white;
        }
</style>

<div class="inbox-wrapper">
    <div class="container">
        <div class="row">
            @await Component.InvokeAsync("MessageSidebarComponentPartial")

            <div class="col-lg-9 col-md-9 col-sm-12">

                <div class="inbox-toolbar">
                    <div class="search-box">
                        <i class="notika-icon notika-search search-icon-fixed"></i>
                        <input type="text" id="draftSearch" placeholder="Taslaklarda ara..." autocomplete="off">
                    </div>
                </div>

                <div class="info-banner">
                    <i class="notika-icon notika-edit"></i>
                    <span>Toplamda <strong>@ViewBag.DraftBoxCount</strong> taslak mesajınız var</span>
                </div>

                <div class="inbox-card">
                    <div class="table-responsive-custom">
                        <table class="inbox-table">
                            <thead>
                                <tr>
                                    <th class="col-receiver">Alıcı</th>
                                    <th class="col-category">Kategori</th>
                                    <th class="col-subject">Konu</th>
                                    <th class="col-date">Tarih</th>
                                    <th class="col-actions">İşlem</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr class="message-row">
                                        <td class="col-receiver" title="@item.ReceiverEmail">
                                            <span style="font-weight: 600; color: var(--text-main);">@item.ReceiverEmail</span>
                                        </td>
                                        <td class="col-category">
                                            @{
                                                var badgeClass = item.Category.CategoryName switch
                                                {
                                                    "Eğitim" => "bg-edu",
                                                    "Sosyal" => "bg-soc",
                                                    "Finans" => "bg-fin",
                                                    _ => "bg-def"
                                                };
                                            }
                                            <span class="cat-badge @badgeClass">@item.Category.CategoryName</span>
                                        </td>
                                        <td class="col-subject">
                                            <a href="/Message/MessageDetail?messageId=@item.MessageId"
                                               style="color: var(--text-main); text-decoration: none;" title="@item.Subject">
                                                @item.Subject
                                            </a>
                                        </td>
                                        <td class="col-date" style="color: var(--text-muted); font-size: 13px;">
                                            @item.SendDate.ToString("dd MMM yyyy")
                                        </td>
                                        <td class="col-actions">
                                            <a href="/Message/DrafMessage?messageId=@item.MessageId" class="btn-go">
                                                Düzenle
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    $(document).ready(function () {
        // Canlı Arama
        $("#draftSearch").on("keyup", function () {
            var value = $(this).val().toLowerCase();
            $(".message-row").filter(function () {
                $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1)
            });
        });
    });
</script>